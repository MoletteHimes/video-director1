# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AI Video Director

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_only_for_server_side

# AI provider: mock | deepseek | openai | anthropic | custom_openai
AI_PROVIDER=mock
AI_MODEL=deepseek-chat
AI_API_KEY=your_api_key
AI_BASE_URL=https://api.deepseek.com


# AI workflow: langgraph | direct
# langgraph = 文案标准化 -> 知识库检索 -> 模型生成 -> 结果合并
# direct = 旧版一步式调用，适合排查问题
AI_WORKFLOW=langgraph
KNOWLEDGE_MIN_SCORE=20

# Optional Anthropic
ANTHROPIC_API_VERSION=2023-06-01

# Optional safety limits
ADMIN_LIBRARY_TOKEN=
ADMIN_LIBRARY_USERNAME=admin
ADMIN_LIBRARY_PASSWORD=
ADMIN_SESSION_SECRET=
ANALYZE_RATE_LIMIT_PER_MINUTE=20
IMAGE_RATE_LIMIT_PER_HOUR=20

# Storyboard image generation provider:
# mock | openai | qwen | openrouter | gemini | custom_openai
IMAGE_PROVIDER=mock
IMAGE_API_KEY=your_image_api_key
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1024x1536
IMAGE_FALLBACK_TO_MOCK=false

# OpenAI
# Broad compatibility default. You may switch to gpt-image-2 only if your OpenAI project has access.
# IMAGE_PROVIDER=openai
# IMAGE_API_BASE_URL=https://api.openai.com/v1
# IMAGE_API_ENDPOINT=/images/generations

# Qwen / DashScope or any OpenAI-compatible image endpoint
# IMAGE_PROVIDER=qwen
# IMAGE_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# IMAGE_API_ENDPOINT=/images/generations
# IMAGE_MODEL=qwen-image

# OpenRouter image-capable model
# IMAGE_PROVIDER=openrouter
# IMAGE_API_BASE_URL=https://openrouter.ai/api/v1
# IMAGE_MODEL=google/gemini-2.5-flash-image

# Gemini native image endpoint
# IMAGE_PROVIDER=gemini
# IMAGE_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# IMAGE_MODEL=gemini-2.5-flash-image

# Optional billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
